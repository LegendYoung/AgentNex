{
  "name": "AgentNex",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:backend": "cd agent && python main.py",
    "dev:frontend": "cd apps/web && npx vite --host",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "start": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "start:docker": "powershell -ExecutionPolicy Bypass -File ./start.ps1 -Docker",
    "stop": "powershell -ExecutionPolicy Bypass -File ./start.ps1 -Stop"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  }
}
